# Create an app at https://developer.spotify.com/dashboard
# Add a redirect URI that matches exactly (e.g. http://localhost:5173/callback for local dev).
VITE_SPOTIFY_CLIENT_ID=

# Optional override; defaults to ${window.location.origin}/callback
# VITE_SPOTIFY_REDIRECT_URI=http://localhost:5173/callback

# Optional: backend origin for split deploy (Render static + API). Omit for local dev (Vite proxies /api).
# VITE_API_URL=https://your-api.onrender.com

